<UserControl x:Class="translation.Controls.FloatingMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:translation.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="425">
    <UserControl.Resources>

        
        <LinearGradientBrush x:Key="ModernGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#46A3FF" Offset="0"/>
            <GradientStop Color="#46A3FF" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#667eea" Offset="0"/>
            <GradientStop Color="#764ba2" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AccentBrush"        Color="#667eea"/>
        <SolidColorBrush x:Key="ForegroundBrush"    Color="#e0e0e0"/>
        <SolidColorBrush x:Key="SubForeground"      Color="#8a8a9a"/>
        <SolidColorBrush x:Key="ButtonBgBrush"      Color="#C4E1FF"/>
        <SolidColorBrush x:Key="ButtonBorderBrush"  Color="#C4E1FF"/>
        <SolidColorBrush x:Key="ButtonFgBrush"      Color="#333333"/>
        <SolidColorBrush x:Key="ResultBgBrush"      Color="#84C1FF"/>
        <SolidColorBrush x:Key="ComboBoxBgBrush"    Color="#C4E1FF"/>
        <SolidColorBrush x:Key="ComboBoxHover"      Color="#C4E1FF"/>
        <SolidColorBrush x:Key="ComboBoxSelected"   Color="#667eea"/>
        <SolidColorBrush x:Key="SeparatorBrush"     Color="#C4E1FF"/>
        <SolidColorBrush x:Key="PrimaryBtnFg"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SettingsPopupBg"    Color="#2A3A5C"/>
        <SolidColorBrush x:Key="GroupLabelBrush"    Color="#A0C4FF"/>

        
        <Style x:Key="CompactButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource ButtonBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ButtonFgBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="Padding"         Value="6,3"/>
            <Setter Property="Margin"          Value="1,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="9"/>
            <Setter Property="Height"          Value="21"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="{DynamicResource ComboBoxHover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="PrimaryCompactButtonStyle" TargetType="Button"
               BasedOn="{StaticResource CompactButtonStyle}">
            <Setter Property="Background"  Value="{DynamicResource PrimaryGradient}"/>
            <Setter Property="Foreground"  Value="{DynamicResource PrimaryBtnFg}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        
        <Style x:Key="IconCompactButtonStyle" TargetType="Button"
               BasedOn="{StaticResource CompactButtonStyle}">
            <Setter Property="Padding"   Value="3,2"/>
            <Setter Property="MinWidth"  Value="18"/>
            <Setter Property="Width"     Value="18"/>
            <Setter Property="Height"    Value="18"/>
        </Style>

        
        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource ButtonBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ButtonFgBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="21"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <TextBlock Text="⚙" FontSize="11"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="{DynamicResource ComboBoxHover}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource ComboBoxBgBrush}"/>
            <Setter Property="Foreground"      Value="{DynamicResource ButtonFgBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="5,2"/>
            <Setter Property="FontSize"        Value="8"/>
            <Setter Property="Height"          Value="21"/>
            <Setter Property="Margin"          Value="1,0"/>
            <Setter Property="ItemContainerStyle" Value="{DynamicResource DefaultComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition/>
                                                    <ColumnDefinition Width="13"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="3,0,0,0"
                                                                  VerticalAlignment="Center"/>
                                                <Path Grid.Column="1"
                                                      Data="M 0 0 L 3 3 L 6 0 Z"
                                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush"
                                                        Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="5,0,13,0"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1" CornerRadius="5" Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#667eea" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.3"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="120">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox"
               BasedOn="{StaticResource CompactComboBoxStyle}">
            <Setter Property="Background"  Value="#3A4E72"/>
            <Setter Property="BorderBrush" Value="#5A7AB2"/>
            <Setter Property="Foreground"  Value="#E0E8FF"/>
            <Setter Property="ItemContainerStyle" Value="{DynamicResource SettingsComboBoxItemStyle}" />
            <Setter Property="Margin"      Value="0"/>
        </Style>

        <Style x:Key="DefaultComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonFgBrush}"/>
            <Setter Property="Padding"    Value="5,3"/>
            <Setter Property="FontSize"   Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ComboBoxHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ComboBoxSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsComboBoxItemStyle" TargetType="ComboBoxItem" BasedOn="{StaticResource DefaultComboBoxItemStyle}">
            <Setter Property="Foreground" Value="#E0E8FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4C6B9C"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#5A7AB2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    
    <Grid x:Name="LayoutRoot">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="0*"/>
        </Grid.ColumnDefinitions>

        
        <Border x:Name="MainBorder"
                Background="{DynamicResource ModernGradient}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="1" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect x:Name="MainShadow" Color="#000000"
                                  BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
            </Border.Effect>
        </Border>

        
        <Grid Margin="4,4,4,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="9"/>
                
                <RowDefinition Height="Auto"/>
                
                <RowDefinition Height="*"/>
                
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0">
                <Border x:Name="DragArea" Background="Transparent"
                        MouseLeftButtonDown="DragArea_MouseLeftButtonDown"
                        Cursor="SizeAll" HorizontalAlignment="Stretch"
                        Padding="1" ToolTip="拖动">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Ellipse Width="3" Height="3" Fill="{DynamicResource AccentBrush}"
                                     Margin="2,0" Opacity="0.6"/>
                            <Ellipse Width="3" Height="3" Fill="{DynamicResource AccentBrush}"
                                     Margin="2,0" Opacity="0.8"/>
                            <Ellipse Width="3" Height="3" Fill="{DynamicResource AccentBrush}"
                                     Margin="2,0" Opacity="1"/>
                        </StackPanel>
                        
                        <Button x:Name="BtnPin" Click="BtnPin_Click"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,-5,5,-5"
                                ToolTip="固定/取消固定浮窗">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TxtPinIcon" Text="📌" FontFamily="Segoe UI Emoji" FontSize="9" Margin="0,0,2,0"/>
                                <TextBlock x:Name="TxtPinText" Text="置顶" FontSize="9" Foreground="{DynamicResource ButtonFgBrush}"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            
            <WrapPanel Grid.Row="1" Orientation="Horizontal"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       Margin="0,4,0,4">

                
                <Grid Width="24" Height="24" Margin="0,0,4,0" ToolTip="pet">
                    <Grid.OpacityMask>
                        <VisualBrush>
                            <VisualBrush.Visual>
                                <Ellipse Width="24" Height="24" Fill="White"/>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Grid.OpacityMask>
                    <Rectangle Fill="White" Panel.ZIndex="0"/>
                    <Image x:Name="GifElement" Stretch="UniformToFill"
                           Panel.ZIndex="1"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Ellipse Width="24" Height="24" Fill="Transparent"
                             Stroke="{DynamicResource AccentBrush}"
                             StrokeThickness="1.5"
                             Panel.ZIndex="2" IsHitTestVisible="False"/>
                </Grid>

                
                
                <Button x:Name="BtnCopy" Click="BtnCopy_Click"
                        Style="{StaticResource CompactButtonStyle}" ToolTip="复制选中文本">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="9" Margin="0,0,2,0"/>
                        <TextBlock Text="复制"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="BtnTranslate" Click="BtnTranslate_Click"
                        Style="{StaticResource CompactButtonStyle}" ToolTip="翻译选中文本">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🌐" FontSize="9" Margin="0,0,2,0"/>
                        <TextBlock Text="翻译"/>
                    </StackPanel>
                </Button>
                
                <ComboBox x:Name="CmbExplainMenu" Width="52"
                          VerticalContentAlignment="Center"
                          ToolTip="解释选中文本 / 查词"
                          Style="{StaticResource CompactComboBoxStyle}">
                    <ComboBoxItem Content="💡 解释" Tag="Explain" IsSelected="True"
                                  PreviewMouseLeftButtonDown="ExplainMenuItem_Click"/>
                    <ComboBoxItem Content="📖 查词" Tag="Lookup"
                                  PreviewMouseLeftButtonDown="ExplainMenuItem_Click"/>
                </ComboBox>

                
                <Border Width="1" Height="16"
                        Background="{DynamicResource SeparatorBrush}" Margin="4,0"/>

                
                <Button x:Name="BtnAskAiInline" Click="BtnAskAiInline_Click"
                        Style="{StaticResource CompactButtonStyle}" ToolTip="向 AI 提问">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💬" FontSize="9" Margin="0,0,2,0"/>
                        <TextBlock Text="问AI"/>
                    </StackPanel>
                </Button>

                
                <Border Width="1" Height="16"
                        Background="{DynamicResource SeparatorBrush}" Margin="4,0"/>

                
                
                <Button x:Name="BtnSearch" Click="BtnSearch_Click"
                        Style="{StaticResource CompactButtonStyle}" ToolTip="搜索选中文本">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="9" Margin="0,0,2,0"/>
                        <TextBlock Text="搜索"/>
                    </StackPanel>
                </Button>
                <ComboBox x:Name="CmbSearchEngine" Width="38"
                          VerticalContentAlignment="Center"
                          ToolTip="选择搜索引擎"
                          Style="{StaticResource CompactComboBoxStyle}">
                    <ComboBoxItem Content="百度"   Tag="Baidu"  IsSelected="True"/>
                    <ComboBoxItem Content="Google" Tag="Google"/>
                    <ComboBoxItem Content="必应"   Tag="Bing"/>
                    <ComboBoxItem Content="秘塔AI" Tag="Metaso"/>
                </ComboBox>
                
                <Button x:Name="BtnOpenUrl" Click="BtnOpenUrl_Click"
                        Style="{StaticResource CompactButtonStyle}" ToolTip="跳转识别到的网页链接">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔗" FontSize="9" Margin="0,0,2,0"/>
                        <TextBlock Text="跳转"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="BtnOpenPath" Click="BtnOpenPath_Click"
                        Style="{StaticResource CompactButtonStyle}"
                        ToolTip="打开本地路径" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="9" Margin="0,0,2,0"/>
                        <TextBlock Text="位置"/>
                    </StackPanel>
                </Button>
                

                
                <Border Width="1" Height="16"
                        Background="{DynamicResource SeparatorBrush}" Margin="4,0"/>

                
                <Grid>
                    <Button x:Name="BtnSettings"
                            Style="{StaticResource SettingsButtonStyle}"
                            ToolTip="显示设置"
                            Click="BtnSettings_Click"/>

                    
                    <Popup x:Name="SettingsPopup"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           Focusable="False"
                           StaysOpen="False"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource SettingsPopupBg}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1" CornerRadius="8"
                                Padding="10,8" Margin="0,4,0,0" MinWidth="160">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="16"
                                                  ShadowDepth="3" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel>

                                
                                <TextBlock Text="显示设置"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#FFFFFF"
                                           Margin="0,0,0,8"/>

                                
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="字号" FontSize="9"
                                               Foreground="#E0E8FF"
                                               VerticalAlignment="Center" Width="30"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button x:Name="BtnIncreaseFont"
                                                Click="BtnIncreaseFont_Click"
                                                Style="{StaticResource IconCompactButtonStyle}"
                                                ToolTip="放大字号">
                                            <TextBlock Text="A+" FontSize="8" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                        <Button x:Name="BtnDecreaseFont"
                                                Click="BtnDecreaseFont_Click"
                                                Style="{StaticResource IconCompactButtonStyle}"
                                                ToolTip="缩小字号" Margin="4,0,0,0">
                                            <TextBlock Text="A−" FontSize="8" FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </DockPanel>

                                
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock Text="字体" FontSize="9"
                                               Foreground="#E0E8FF"
                                               VerticalAlignment="Center" Width="30"/>
                                    <ComboBox x:Name="CmbFontFamily"
                                              SelectionChanged="CmbFontFamily_SelectionChanged"
                                              Width="80" VerticalContentAlignment="Center"
                                              ToolTip="切换字体"
                                              Style="{StaticResource SettingsComboBoxStyle}">
                                        <ComboBoxItem Content="宋体" Tag="SimSun" IsSelected="True"/>
                                        <ComboBoxItem Content="黑体" Tag="SimHei"/>
                                        <ComboBoxItem Content="楷体" Tag="KaiTi"/>
                                    </ComboBox>
                                </DockPanel>

                                
                                <DockPanel>
                                    <TextBlock Text="主题" FontSize="9"
                                               Foreground="#E0E8FF"
                                               VerticalAlignment="Center" Width="30"/>
                                    <Button x:Name="BtnTheme" Click="BtnTheme_Click"
                                            ToolTip="切换深色 / 浅色主题"
                                            Height="21" Width="80" Cursor="Hand"
                                            Background="#3A4E72" BorderBrush="#5A7AB2"
                                            BorderThickness="1">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="5">
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center">
                                                        <TextBlock Text="🌓" FontSize="9"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,4,0"/>
                                                        <TextBlock Text="切换主题" FontSize="8"
                                                                   Foreground="#E0E8FF"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border"
                                                                Property="BorderBrush"
                                                                Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="border"
                                                                Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DockPanel>

                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

            </WrapPanel>
            

            
            <Border Grid.Row="2" x:Name="ResultContainer" Visibility="Collapsed"
                    Background="{DynamicResource ResultBgBrush}"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="5" Margin="0,4,0,4">
                <Border.Effect>
                    <DropShadowEffect x:Name="ResultShadow" Color="#667eea"
                                      BlurRadius="8" ShadowDepth="0" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        
                        <RowDefinition Height="*"/>
                        
                        <RowDefinition Height="Auto"/>
                        
                    </Grid.RowDefinitions>

                    
                    <Grid x:Name="AskAiPanel" Grid.Row="0"
                          Visibility="Collapsed" Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtAskAiInput" Grid.Column="0"
                                 Height="20" Padding="2" FontSize="9"
                                 KeyDown="TxtAskAiInput_KeyDown"
                                 HorizontalAlignment="Stretch"/>
                        <Button x:Name="BtnSubmitAskAi" Grid.Column="1"
                                Click="BtnSubmitAskAi_Click" Content="发送"
                                Style="{StaticResource CompactButtonStyle}"
                                Margin="5,0,0,0"/>
                    </Grid>

                    
                    <ScrollViewer x:Name="ResultScrollViewer" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBox x:Name="ResultText" IsReadOnly="True"
                                 BorderThickness="0" Background="Transparent"
                                 FontSize="9" FontFamily="Microsoft YaHei UI"
                                 Foreground="{DynamicResource ForegroundBrush}"
                                 TextWrapping="Wrap" Padding="3"/>
                    </ScrollViewer>

                    
                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            
                            <ColumnDefinition Width="*"/>
                            
                            <ColumnDefinition Width="Auto"/>
                            
                        </Grid.ColumnDefinitions>

                        
                        <TextBlock x:Name="TimerDisplay" Grid.Column="0"
                                   Text="⏱ 0.00s" FontSize="8"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Opacity="0.9"/>

                        
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            
                            <Button x:Name="BtnSaveNote" Click="BtnSaveNote_Click"
                                    Style="{StaticResource CompactButtonStyle}"
                                    ToolTip="保存选中文本为笔记"
                                    Padding="5,2" Height="18">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📌" FontSize="8" Margin="0,0,2,0"/>
                                    <TextBlock Text="保存笔记" FontSize="8"/>
                                </StackPanel>
                            </Button>
                            
                            <Button x:Name="BtnSaveAiResult" Click="BtnSaveAiResult_Click"
                                    Style="{StaticResource CompactButtonStyle}"
                                    ToolTip="保存 AI 结果为笔记"
                                    Padding="5,2" Height="18" Margin="4,0,0,0"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📌" FontSize="8" Margin="0,0,2,0"/>
                                    <TextBlock Text="存结果" FontSize="8"/>
                                </StackPanel>
                            </Button>
                            
                            <Button x:Name="BtnCopyResult" Click="BtnCopyResult_Click"
                                    Style="{StaticResource CompactButtonStyle}"
                                    ToolTip="复制结果文本"
                                    Padding="5,2" Height="18" Margin="4,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✅" FontSize="8" Margin="0,0,2,0"/>
                                    <TextBlock Text="复制结果" FontSize="8"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
