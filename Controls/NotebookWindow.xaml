<Window x:Class="translation.Controls.NotebookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
        Title="📒 Notebook"
        Height="780" Width="1240"
		MinHeight="600" MinWidth="900"
		WindowStartupLocation="CenterScreen"
		Background="#FFFFFF"
		FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI">
	<Window.Resources>
		<SolidColorBrush x:Key="PaperBase"       Color="#FFFFFF"/>
		<SolidColorBrush x:Key="PaperAged"       Color="#FFFFFF"/>
		<SolidColorBrush x:Key="PaperLines"      Color="#EDE3CC"/>
		<SolidColorBrush x:Key="PaperShadow"     Color="#DDD0B3"/>
		<SolidColorBrush x:Key="MarginRed"       Color="#D9534F"/>
		<SolidColorBrush x:Key="InkBlue"         Color="#2E4A6E"/>
		<SolidColorBrush x:Key="InkBlueLight"    Color="#E8EFF8"/>
		<SolidColorBrush x:Key="InkBlueMid"      Color="#96AEC8"/>
		<SolidColorBrush x:Key="LeatherBrown"    Color="#8B5E1E"/>
		<SolidColorBrush x:Key="LeatherLight"    Color="#FAF0DC"/>
		<SolidColorBrush x:Key="StickyYellow"    Color="#FEFCE7"/>
		<SolidColorBrush x:Key="StickyBorder"    Color="#F0E68C"/>
		<SolidColorBrush x:Key="GreenTag"        Color="#4A7C59"/>
		<SolidColorBrush x:Key="GreenTagLight"   Color="#EAF3EE"/>
		<SolidColorBrush x:Key="TextInk"         Color="#2A2016"/>
		<SolidColorBrush x:Key="TextFaded"       Color="#7A6A50"/>
		<SolidColorBrush x:Key="TextMuted"       Color="#B0A080"/>
		<SolidColorBrush x:Key="HoverTint"       Color="#F0E9D5"/>
		<SolidColorBrush x:Key="SelectedTint"    Color="#DAE8F5"/>
		<Style x:Key="NotePageCard" TargetType="Border">
			<Setter Property="Background"      Value="{StaticResource PaperBase}"/>
			<Setter Property="BorderBrush"     Value="{StaticResource PaperShadow}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius"    Value="3,8,8,3"/>
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect BlurRadius="18" ShadowDepth="4"
                                      Opacity="0.18" Color="#8B5E1E" Direction="315"/>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="SpineCard" TargetType="Border" BasedOn="{StaticResource NotePageCard}">
			<Setter Property="CornerRadius" Value="8,3,3,8"/>
			<Setter Property="Background"   Value="#FFFFFF"/>
		</Style>
		<Style x:Key="StickyCard" TargetType="Border">
			<Setter Property="Background"      Value="{StaticResource StickyYellow}"/>
			<Setter Property="BorderBrush"     Value="{StaticResource StickyBorder}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="CornerRadius"    Value="3,3,8,8"/>
			<Setter Property="Effect">
				<Setter.Value>
					<DropShadowEffect BlurRadius="14" ShadowDepth="5"
                                      Opacity="0.20" Color="#C4862A" Direction="310"/>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="BtnInk" TargetType="Button">
			<Setter Property="Background"      Value="{StaticResource InkBlue}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="FontFamily"      Value="Palatino Linotype, Georgia, Microsoft YaHei UI"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="Padding"         Value="14,8"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="#24395A"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="#1C2E47"/>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter Property="Background" Value="#96AEC8"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="BtnLeather" TargetType="Button" BasedOn="{StaticResource BtnInk}">
			<Setter Property="Background" Value="{StaticResource LeatherBrown}"/>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#6E4A14"/>
				</Trigger>
				<Trigger Property="IsEnabled" Value="False">
					<Setter Property="Background" Value="#C4A070"/>
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style x:Key="BtnPaper" TargetType="Button">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="{StaticResource TextFaded}"/>
			<Setter Property="FontFamily"      Value="Palatino Linotype, Georgia, Microsoft YaHei UI"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="Padding"         Value="12,7"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush"     Value="{StaticResource PaperShadow}"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background"   Value="{StaticResource HoverTint}"/>
								<Setter Property="BorderBrush"  Value="{StaticResource InkBlue}"/>
								<Setter Property="Foreground"   Value="{StaticResource InkBlue}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="InkBoxStyle" TargetType="TextBox">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="{StaticResource TextInk}"/>
			<Setter Property="FontFamily"      Value="Palatino Linotype, Georgia, Microsoft YaHei UI"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="Padding"         Value="6,7"/>
			<Setter Property="BorderThickness" Value="0,0,0,1.5"/>
			<Setter Property="BorderBrush"     Value="{StaticResource PaperShadow}"/>
			<Setter Property="CaretBrush"      Value="{StaticResource InkBlue}"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
							<ScrollViewer x:Name="PART_ContentHost"
                                          VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True">
								<Setter Property="BorderBrush" Value="{StaticResource InkBlue}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="ContentBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InkBoxStyle}">
			<Setter Property="TextWrapping"                Value="Wrap"/>
			<Setter Property="AcceptsReturn"               Value="True"/>
			<Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
			<Setter Property="FontSize"                    Value="14"/>
			<Setter Property="BorderThickness"             Value="0"/>
			<Setter Property="Padding"                     Value="0,4"/>
		</Style>
		<Style x:Key="ComboStyle" TargetType="ComboBox">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="{StaticResource TextFaded}"/>
			<Setter Property="FontFamily"      Value="Palatino Linotype, Georgia, Microsoft YaHei UI"/>
			<Setter Property="FontSize"        Value="12"/>
			<Setter Property="Padding"         Value="4,5"/>
			<Setter Property="BorderThickness" Value="0,0,0,1.5"/>
			<Setter Property="BorderBrush"     Value="{StaticResource PaperShadow}"/>
			<Setter Property="Height"          Value="34"/>
		</Style>
		<Style x:Key="NoteItemStyle" TargetType="ListBoxItem">
			<Setter Property="Padding"         Value="0"/>
			<Setter Property="Margin"          Value="0,3"/>
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ListBoxItem">
						<Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2,5,5,2"
                                Padding="0"
                                Margin="{TemplateBinding Margin}">
							<ContentPresenter/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="ItemBorder" Property="Background"
                                        Value="{StaticResource HoverTint}"/>
							</Trigger>
							<Trigger Property="IsSelected" Value="True">
								<Setter TargetName="ItemBorder" Property="Background"
                                        Value="{StaticResource SelectedTint}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		<Style x:Key="CleanList" TargetType="ListBox">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
		</Style>
		<Style x:Key="SectionLabel" TargetType="TextBlock">
			<Setter Property="FontFamily" Value="Palatino Linotype, Georgia, Microsoft YaHei UI"/>
			<Setter Property="FontSize"   Value="11"/>
			<Setter Property="FontStyle"  Value="Italic"/>
			<Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
			<Setter Property="Margin"     Value="0,0,0,8"/>
		</Style>
		<Style x:Key="TagPill" TargetType="Border">
			<Setter Property="Background"   Value="{StaticResource InkBlueLight}"/>
			<Setter Property="CornerRadius" Value="2"/>
			<Setter Property="Padding"      Value="6,2"/>
			<Setter Property="Margin"       Value="0,0,4,0"/>
		</Style>
		<DrawingBrush x:Key="RuledLineBrush" TileMode="Tile"
                      Viewport="0,0,1,28" ViewportUnits="Absolute">
			<DrawingBrush.Drawing>
				<DrawingGroup>
					<GeometryDrawing Brush="#FFFFFF">
						<GeometryDrawing.Geometry>
							<RectangleGeometry Rect="0,0,1,28"/>
						</GeometryDrawing.Geometry>
					</GeometryDrawing>
					<GeometryDrawing>
						<GeometryDrawing.Pen>
							<Pen Brush="#EDE3CC" Thickness="0.7"/>
						</GeometryDrawing.Pen>
						<GeometryDrawing.Geometry>
							<LineGeometry StartPoint="0,27.5" EndPoint="1,27.5"/>
						</GeometryDrawing.Geometry>
					</GeometryDrawing>
				</DrawingGroup>
			</DrawingBrush.Drawing>
		</DrawingBrush>
	</Window.Resources>
	<Grid Background="{StaticResource PaperAged}">
		<Grid.RowDefinitions>
			<RowDefinition Height="62"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>
		<Border Grid.Row="0"
                Background="#2E4A6E"
                BorderBrush="#1C2E47"
                BorderThickness="0,0,0,3">
			<Border.Effect>
				<DropShadowEffect BlurRadius="10" ShadowDepth="3"
                                  Opacity="0.28" Color="#1C2E47"/>
			</Border.Effect>
			<Grid Margin="24,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="86.533"/>
					<ColumnDefinition Width="33.467"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Grid.ColumnSpan="2">
					<Border Width="6" Height="38" CornerRadius="0,0,3,3"
                            Margin="0,0,14,0" Background="#C4862A" VerticalAlignment="Bottom"/>
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="学习笔记本"
								   FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI"
								   FontSize="20" FontWeight="Bold" FontStyle="Italic"
								   Foreground="#FFFFFF"/>
					</StackPanel>
				</StackPanel>
				<StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,8,0">
					<Ellipse Width="8" Height="8" Fill="#96AEC8" Opacity="0.5" Margin="0,0,6,0"/>
					<Ellipse Width="8" Height="8" Fill="#96AEC8" Opacity="0.5" Margin="0,0,6,0"/>
					<Ellipse Width="8" Height="8" Fill="#96AEC8" Opacity="0.5"/>
				</StackPanel>
			</Grid>
		</Border>
		<Grid Grid.Row="1" Margin="14,12,14,12">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="260" MinWidth="150"/>
				<ColumnDefinition Width="10"/>
				<ColumnDefinition Width="*" MinWidth="300"/>
				<ColumnDefinition Width="10"/>
				<ColumnDefinition Width="300" MinWidth="200"/>
			</Grid.ColumnDefinitions>
			<GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>
			<GridSplitter Grid.Column="3" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>
			<Border Grid.Column="0" Style="{StaticResource SpineCard}">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="4"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<Rectangle Grid.Column="0" Fill="#D9534F" RadiusX="2" RadiusY="2"/>
					<Grid Grid.Column="1">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						<StackPanel Grid.Row="0" Margin="12,14,14,10">
							<TextBlock Text="目  录" Style="{StaticResource SectionLabel}"
									   FontSize="12"/>
							<Grid Margin="0,0,0,10">
								<TextBox x:Name="TxtSearch"
                                         Style="{StaticResource InkBoxStyle}"
                                         Text="搜索笔记..."
                                         Foreground="{StaticResource TextMuted}"
                                         GotFocus="TxtSearch_GotFocus"
                                         LostFocus="TxtSearch_LostFocus"
                                         TextChanged="TxtSearch_TextChanged"/>
								<TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center"
                                           HorizontalAlignment="Right" Margin="0,0,0,2"
                                           Foreground="{StaticResource TextMuted}"/>
							</Grid>
							<ComboBox x:Name="CmbTags"
                                      Style="{StaticResource ComboStyle}"
                                      IsEditable="True"
                                      SelectionChanged="CmbTags_SelectionChanged"
                                      TextBoxBase.TextChanged="CmbTags_TextChanged"/>
						</StackPanel>
						<Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                                Background="{StaticResource PaperLines}" Margin="10,0,14,0"/>
						<ListBox x:Name="LstNotes"
                                 Grid.Row="1"
                                 Style="{StaticResource CleanList}"
                                 ItemContainerStyle="{StaticResource NoteItemStyle}"
                                 SelectionMode="Extended"
                                 SelectionChanged="LstNotes_SelectionChanged"
                                 Margin="6,8,8,8">
							<ListBox.ContextMenu>
								<ContextMenu FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI"
                                             FontSize="13">
									<MenuItem Header="📋 复制内容" Click="MenuCopy_Click"/>
									<MenuItem Header="✏️ 编辑笔记" Click="MenuEdit_Click"/>
									<Separator/>
									<MenuItem Header="🗑️ 删除笔记" Click="MenuDelete_Click"
                                              Foreground="#C0392B"/>
								</ContextMenu>
							</ListBox.ContextMenu>
							<ListBox.ItemTemplate>
								<DataTemplate>
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="3"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<Rectangle Grid.Column="0" Fill="#96AEC8"
                                                   RadiusX="1" RadiusY="1" Margin="0,3,0,3"/>
										<StackPanel Grid.Column="1" Margin="10,8,8,8">
											<TextBlock Text="{Binding Content}"
                                                       FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextInk}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="38"
                                                       TextWrapping="Wrap"/>
											<TextBlock Margin="0,4,0,0"
                                                       FontSize="10"
                                                       FontStyle="Italic"
                                                       Foreground="{StaticResource TextMuted}">
												<Run Text="{Binding Source}"/>
												<Run Text=" · "/>
												<Run Text="{Binding CreatedAt, StringFormat=MM/dd HH:mm}"/>
											</TextBlock>
											<ItemsControl Margin="0,4,0,0"
                                                          ItemsSource="{Binding Tags}">
												<ItemsControl.ItemsPanel>
													<ItemsPanelTemplate>
														<WrapPanel/>
													</ItemsPanelTemplate>
												</ItemsControl.ItemsPanel>
												<ItemsControl.ItemTemplate>
													<DataTemplate>
														<Border Style="{StaticResource TagPill}"
                                                                Margin="0,0,4,2">
															<TextBlock Text="{Binding}"
                                                                       FontSize="10"
                                                                       Foreground="{StaticResource InkBlue}"
                                                                       FontWeight="Medium"/>
														</Border>
													</DataTemplate>
												</ItemsControl.ItemTemplate>
											</ItemsControl>
										</StackPanel>
									</Grid>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
						<Border Grid.Row="2" BorderBrush="{StaticResource PaperLines}"
                                BorderThickness="0,1,0,0" Padding="12,7">
							<TextBlock x:Name="TxtSelectedCount"
                                       FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI"
                                       FontSize="11" 
                                       Text="已选择: 0 条笔记"
                                       Foreground="{StaticResource TextMuted}"/>
						</Border>
					</Grid>
				</Grid>
			</Border>
			<Border Grid.Column="2" Style="{StaticResource NotePageCard}">
				<Grid>
					<Rectangle Fill="{StaticResource RuledLineBrush}" Opacity="1"
                               RadiusX="3" RadiusY="8"/>
					<Rectangle Width="1.5" HorizontalAlignment="Left" Margin="48,0,0,0"
                                Fill="#E8B4B2" Opacity="0.6"/>
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						<Border Grid.Row="0" Padding="56,11,16,11"
								BorderBrush="{StaticResource PaperLines}"
								BorderThickness="0,0,0,1"
								Background="#FFFFFF">
							<Grid>
								<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
									<Rectangle Width="3" Height="20" RadiusX="1" RadiusY="1"
                                               Fill="{StaticResource InkBlueMid}" Margin="0,0,10,0"/>
									<TextBlock Text="笔记详情"
                                               FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI"
                                               FontSize="13" FontStyle="Italic"
                                               Foreground="{StaticResource TextFaded}"
                                               VerticalAlignment="Center"/>
								</StackPanel>
								<Button x:Name="BtnToggleEdit"
                                        Content="✏ 编辑"
                                        Style="{StaticResource BtnPaper}"
                                        HorizontalAlignment="Right"
                                        Click="BtnToggleEdit_Click"
                                        FontSize="12" Padding="10,5"/>
							</Grid>
						</Border>
						<ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      PreviewMouseWheel="UIElement_OnPreviewMouseWheel"
                                      Padding="56,14,20,14">
							<Grid>
								<markdig:MarkdownViewer
                                    x:Name="MarkdownDetailContent"
                                    Visibility="Visible"
                                    PreviewMouseWheel="UIElement_OnPreviewMouseWheel"/>
								<TextBox x:Name="TxtEditContent"
										 Style="{StaticResource ContentBoxStyle}"
										 PreviewMouseWheel="UIElement_OnPreviewMouseWheel"
										 Visibility="Collapsed"
										 MinHeight="200"
										 FontSize="14"/>
							</Grid>
						</ScrollViewer>
						<Border Grid.Row="2" Padding="56,10,20,12"
								BorderBrush="{StaticResource PaperLines}"
								BorderThickness="0,1,0,0"
								Background="#FFFFFF">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0">
									<TextBlock Text="来源 / Source"
                                               FontFamily="Palatino Linotype, Georgia"
                                               FontSize="10" FontStyle="Italic"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,3"/>
									<TextBlock x:Name="TxtDetailSource"
                                               FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI"
                                               FontSize="12"
                                               Foreground="{StaticResource TextFaded}"
                                               TextTrimming="CharacterEllipsis"/>
									<TextBox x:Name="TxtEditSource"
                                             Style="{StaticResource InkBoxStyle}"
                                             FontSize="12" Visibility="Collapsed"/>
								</StackPanel>
								<StackPanel Grid.Column="1" Margin="16,0,0,0">
									<TextBlock Text="标签 / Tags"
                                               FontFamily="Palatino Linotype, Georgia"
                                               FontSize="10" FontStyle="Italic"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0,0,0,3"/>
									<TextBlock x:Name="TxtDetailTags"
                                               FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI"
                                               FontSize="12"
                                               Foreground="{StaticResource InkBlue}"
                                               TextTrimming="CharacterEllipsis"/>
									<TextBox x:Name="TxtEditTags"
                                             Style="{StaticResource InkBoxStyle}"
                                             FontSize="12" Visibility="Collapsed"/>
								</StackPanel>
							</Grid>
						</Border>
					</Grid>
				</Grid>
			</Border>
			<Border Grid.Column="4" Style="{StaticResource StickyCard}">
				<Grid>
					<Path HorizontalAlignment="Right" VerticalAlignment="Top"
                          Data="M 0,0 L 20,0 L 20,20 Z"
                          Fill="#E0D860" Margin="0,0,0,0"/>
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						<Border Grid.Row="0" Padding="16,12,16,10"
                                BorderBrush="{StaticResource StickyBorder}"
                                BorderThickness="0,0,0,1.5">
							<StackPanel Orientation="Horizontal">
								<Border Width="28" Height="28" CornerRadius="14"
                                        Background="#F5E642" Margin="0,0,10,0"
                                        BorderBrush="#C8C020" BorderThickness="1.5">
									<TextBlock Text="📌" FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
								</Border>
								<StackPanel VerticalAlignment="Center">
									<TextBlock Text="AI 学习助手"
                                               FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI"
                                               FontSize="14" FontWeight="Bold" FontStyle="Italic"
                                               Foreground="{StaticResource TextInk}"/>
									<TextBlock Text="智能整理 · 答疑解惑"
                                               FontFamily="Palatino Linotype, Georgia"
                                               FontSize="10" FontStyle="Italic"
                                               Foreground="{StaticResource TextFaded}"/>
								</StackPanel>
							</StackPanel>
						</Border>
						<Border Grid.Row="1" Margin="12,10,12,0"
                                Background="#FFFDE8"
                                CornerRadius="3" BorderThickness="1"
                                BorderBrush="{StaticResource StickyBorder}">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto"/>
									<RowDefinition Height="*"/>
								</Grid.RowDefinitions>
								<TextBlock Grid.Row="0"
                                           Text="— 回复 —"
                                           FontFamily="Palatino Linotype, Georgia"
                                           FontSize="10" FontStyle="Italic"
                                           Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"
                                           Margin="0,7,0,4"/>
								<ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              PreviewMouseWheel="UIElement_OnPreviewMouseWheel">
									<markdig:MarkdownViewer
                                        x:Name="TxtAiResponse"
                                        Margin="12,2,12,10"
                                        PreviewMouseWheel="UIElement_OnPreviewMouseWheel"
                                        FontFamily="Palatino Linotype, Georgia, Microsoft YaHei UI"
                                        Markdown=""/>
								</ScrollViewer>
							</Grid>
						</Border>
						<GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Transparent" Cursor="SizeNS" Margin="12,0,12,0"/>
						<Grid Grid.Row="3" Margin="12,2,12,0">
							<Border Background="#FFFBEE"
									BorderBrush="{StaticResource StickyBorder}"
									BorderThickness="1" CornerRadius="3"
									Padding="2">
								<Grid>
									<TextBox x:Name="TxtQuestion"
											 Style="{StaticResource ContentBoxStyle}"
											 Text=""
											 AcceptsReturn="True"
											 PreviewKeyDown="TxtQuestion_PreviewKeyDown"
											 MinHeight="62"
											 Padding="8,8,8,42"
											 FontSize="13"
											 Background="Transparent"/>
									<TextBlock Text="输入问题...(可对当前笔记进行提问，也可勾选多个笔记条目进行提问）"
											   IsHitTestVisible="False"
											   Foreground="{StaticResource TextMuted}"
											   FontSize="10"
											   FontStyle="Italic"
											   Margin="0,0,0,0">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Visibility" Value="Collapsed"/>
												<Style.Triggers>
													<DataTrigger Binding="{Binding Text, ElementName=TxtQuestion}" Value="">
														<Setter Property="Visibility" Value="Visible"/>
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>
									<StackPanel Orientation="Horizontal" Focusable="False" 
												HorizontalAlignment="Right"
												VerticalAlignment="Bottom"
												Margin="0,0,4,4">
										<Button Content="🧹"
												ToolTip="清空回复"
												Style="{StaticResource BtnPaper}"
												Width="32" Height="32"
												Margin="0,0,4,0"
												Padding="0"
												Click="BtnClearAi_Click"/>
										<Button Content="➤"
												ToolTip="发送(Enter)/换行(Shift+Enter)"
												Style="{StaticResource BtnInk}"
												Width="32" Height="32"
												Padding="0"
												Click="BtnAskAi_Click"/>
									</StackPanel>
								</Grid>
							</Border>
						</Grid>
						<Grid Grid.Row="4" Margin="12,10,12,14">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="8"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Button x:Name="BtnSaveToCurrent"
                                    Grid.Column="0"
                                    Content="📎 追加到笔记"
                                    Style="{StaticResource BtnPaper}"
                                    FontSize="12" Padding="8,7"
                                    Click="BtnSaveToCurrent_Click"/>
							<Button x:Name="BtnSaveAsNew"
                                    Grid.Column="2"
                                    Content="🆕 另存新笔记"
                                    Style="{StaticResource BtnLeather}"
                                    FontSize="12" Padding="8,7"
                                    Click="BtnSaveAsNew_Click"/>
						</Grid>
					</Grid>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Window>
