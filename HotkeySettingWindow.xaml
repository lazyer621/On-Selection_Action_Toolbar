<Window x:Class="translation.HotkeySettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快捷键设置"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="宋体, Times New Roman"/>
            <Setter Property="FontSize"   Value="14"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="宋体, Times New Roman"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="宋体, Times New Roman"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Width"      Value="80"/>
            <Setter Property="Height"     Value="32"/>
            <Setter Property="Cursor"     Value="Hand"/>
        </Style>
    </Window.Resources>
    <Border Background="White"
            Padding="28,24,28,20"
            BorderBrush="#D2D2D2"
            BorderThickness="1">
        <StackPanel>
            <TextBlock Text="修饰键（至少选一项）"
                       FontSize="13"
                       Foreground="#505050"/>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
                <CheckBox x:Name="ChkCtrl" Content="Ctrl"
                          Checked="Mod_Changed" Unchecked="Mod_Changed"/>
                <Border Width="16"/>
                <CheckBox x:Name="ChkAlt" Content="Alt"
                          Checked="Mod_Changed" Unchecked="Mod_Changed"/>
            </StackPanel>
            <TextBlock Text="主键（字母 / 数字 / F1–F12）"
                       FontSize="13"
                       Foreground="#505050"/>
            <Border x:Name="KeyCaptureBorder"
                    Height="38"
                    Margin="0,6,0,0"
                    BorderBrush="#B4B4B4"
                    BorderThickness="1"
                    Background="#F8F8F8"
                    Cursor="IBeam">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="#0078D4"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBox x:Name="TxtKey"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         TextAlignment="Center"
                         VerticalContentAlignment="Center"
                         FontFamily="宋体, Times New Roman"
                         FontSize="15"
                         Foreground="#1E1E1E"
                         CaretBrush="Transparent"
                         Focusable="True"
                         PreviewKeyDown="TxtKey_PreviewKeyDown"
                         GotFocus="TxtKey_GotFocus"
                         LostFocus="TxtKey_LostFocus"/>
            </Border>
            <TextBlock x:Name="TbHint"
                       FontSize="12"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       Foreground="#646464"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="BtnCancel" Content="取消"
                        Background="#F0F0F0"
                        Foreground="#1E1E1E"
                        BorderBrush="#B4B4B4"
                        Click="BtnCancel_Click"/>
                <Border Width="10"/>
                <Button x:Name="BtnOk" Content="确定"
                        Background="#0078D4"
                        Foreground="White"
                        BorderBrush="#0064B4"
                        IsEnabled="False"
                        Click="BtnOk_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
